{
  "id": "north-star-mcp-project",
  "name": "North Star MCP Development",
  "vision": "Build an MCP server that keeps AI assistants focused on project goals and prevents scope creep through alignment validation and progress tracking",
  "successCriteria": [
    "MCP server successfully connects to Roo Code",
    "All 8 tools work correctly (initialize, check_alignment, validate_scope, etc.)",
    "Alignment scoring accurately identifies misaligned tasks",
    "Master plan persists across sessions in .north-star/ directory",
    "Documentation is clear and includes real examples",
    "Can be used immediately after npm install && npm run build"
  ],
  "constraints": [
    {
      "id": "c1",
      "type": "scope",
      "description": "No UI or web interface in v1",
      "rationale": "Focus on core MCP functionality. CLI/MCP interface is sufficient for initial version.",
      "createdAt": "2025-01-13T00:00:00.000Z"
    },
    {
      "id": "c2",
      "type": "technical",
      "description": "Use file-based storage only (no database)",
      "rationale": "Keep it simple and portable. JSON files are easy to inspect and version control.",
      "createdAt": "2025-01-13T00:00:00.000Z"
    },
    {
      "id": "c3",
      "type": "complexity",
      "description": "No AI/ML for alignment scoring - use rule-based approach",
      "rationale": "Deterministic scoring is more predictable and debuggable. No external API dependencies.",
      "createdAt": "2025-01-13T00:00:00.000Z"
    },
    {
      "id": "c4",
      "type": "scope",
      "description": "Single project support only (no multi-project management)",
      "rationale": "One master plan per workspace keeps architecture simple.",
      "createdAt": "2025-01-13T00:00:00.000Z"
    }
  ],
